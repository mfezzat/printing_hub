# ── Printing Hub Environment Configuration ──
# Copy this file to .env and fill in all values before running.

# App
SECRET_KEY=replace-with-64-char-random-string
DEBUG=false

# Database
DB_PASSWORD=replace-with-strong-password

# Redis
REDIS_URL=redis://redis:6379/0

# S3 / MinIO file storage
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=replace-with-minio-user
S3_SECRET_KEY=replace-with-minio-password
S3_BUCKET=printing-hub-files
S3_REGION=auto

# Twilio (WhatsApp + SMS OTP)
# Sign up at https://www.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886
TWILIO_FROM_SMS=+1xxxxxxxxxx

# Paymob (Egypt payments)
# Sign up at https://accept.paymob.com
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_CARD=
PAYMOB_INTEGRATION_FAWRY=
PAYMOB_INTEGRATION_VODAFONE=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# Website integration
WEBSITE_API_KEY=replace-with-shared-secret

# CORS — add your domain(s)
ALLOWED_ORIGINS=["https://yourdomain.com","http://localhost:3000"]
